# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker: postgresql+psycopg://postgres:postgres@localhost:5432/talktome
# Supabase:     postgresql+psycopg://postgres:[password]@db.[project].supabase.co:5432/postgres
# Railway:      from Railway dashboard → PostgreSQL → Variables → DATABASE_URL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/talktome

# ── Redis (optional — caching disabled if blank) ──────────────────────────────
# Local Docker: redis://localhost:6379
# Upstash:      rediss://:[password]@[host].upstash.io:6380
REDIS_URL=

# ── AI provider ───────────────────────────────────────────────────────────────
# Groq (free, fast):   https://console.groq.com → API Keys
# OpenAI:              https://platform.openai.com → API Keys
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=https://api.groq.com/openai/v1

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON list of allowed frontend origins
# Local:       ["http://localhost:5173"]
# Production:  ["https://yourdomain.vercel.app","https://talktome.yourdomain.com"]
CORS_ORIGINS=["http://localhost:5173"]

# ── Monitoring (optional — Sentry disabled if blank) ──────────────────────────
# https://sentry.io → Projects → DSN
SENTRY_DSN=

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
WORKERS=2
